#!/usr/bin/env ruby
# frozen_string_literal: true

require "readline"
require_relative "../lib/text_adventures"

module TextAdventures
  class CLI
    EXIT_COMMANDS = %w[exit quit].freeze

    def initialize(input: $stdin, output: $stdout, game: self.class.default_game, line_reader: nil)
      @input = input
      @output = output
      @game = game
      @line_reader = line_reader
    end

    def run
      output.puts game.handle("look")

      loop do
        command = read_command
        break unless command

        command = command.strip
        break if EXIT_COMMANDS.include?(command.downcase)
        next if command.empty?

        output.puts game.handle(command)
        break if game.player.dead?
      end

      output.puts "\nThanks for playing."
    end

    private

    attr_reader :input, :output, :game, :line_reader

    def read_command
      prompt = "\n#{prompt_label} > "
      command = interactive_input? ? read_interactive_command(prompt) : read_plain_command(prompt)
      record_history(command)
      command
    end

    def read_plain_command(prompt)
      output.print prompt
      input.gets
    end

    def read_interactive_command(prompt)
      return line_reader.call(prompt) if line_reader

      Readline.readline(prompt, false)
    end

    def record_history(command)
      command = command.to_s.strip
      return if command.empty?
      return unless interactive_input?
      return if line_reader

      Readline::HISTORY << command
    end

    def interactive_input?
      return true if line_reader

      input.equal?($stdin) && output.equal?($stdout) && input.tty? && output.tty?
    end

    def prompt_label
      scene = game.current_scene
      return "Ruins L#{game.dungeon.level}" if scene.name == :ruins && game.dungeon
      return scene.display_name if scene.respond_to?(:display_name)

      scene.name.to_s.split("_").map(&:capitalize).join(" ")
    end

    def self.default_game
      seed = ENV["TEXT_ADVENTURES_RANDOM_SEED"]
      return Game.new unless seed

      Game.new(random: Random.new(Integer(seed)))
    end
  end
end

TextAdventures::CLI.new.run if $PROGRAM_NAME == __FILE__
